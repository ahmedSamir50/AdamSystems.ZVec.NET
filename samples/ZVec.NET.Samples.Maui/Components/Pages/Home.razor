@page "/"
@using ZVec.NET.Samples.Shared
@using ZVec.NET.Samples.Shared.Data
@using ZVec.NET.Samples.Shared.LmStudio
@using ZVec.NET.Samples.Shared.Rag
@inject RagIngestService Ingest
@inject RagAskService Ask
@inject LmStudioStatusProbe StatusProbe
@inject IZvecCollection<ZVec.NET.Samples.Shared.Models.RagDocument> Collection

<h1>ZVec.NET Edge RAG</h1>
<p class="status">.NET 10 · AppData mmap · EmbeddingGemma + Gemma 4 E2B (concurrent)</p>

<div class="status-bar">
    <div><strong>LM Studio:</strong> @_statusMessage</div>
    <div><strong>Datasets:</strong> @_datasetMessage</div>
    <button class="btn btn-sm" @onclick="RefreshStatusAsync">Refresh</button>
</div>

<section>
    <h2>Ingest</h2>
    <textarea @bind="_ingestText" rows="6" style="width:100%" placeholder="Paste text to embed and store on-device…"></textarea>
    <div class="actions">
        <button class="btn btn-primary" disabled="@_busy" @onclick="IngestAsync">Ingest text</button>
        <button class="btn" disabled="@_busy" @onclick="IngestFixturesAsync">Ingest T0 fixtures</button>
    </div>
    <p>@_ingestMessage</p>
    <p>Collection docs: <strong>@_docCount</strong> · Path: <code>@Collection.Path</code></p>
</section>

<section>
    <h2>Ask</h2>
    <input @bind="_question" style="width:100%" placeholder="Ask a question about ingested content…" />
    <div class="actions">
        <button class="btn btn-primary" disabled="@_busy" @onclick="AskAsync">Ask</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(_answer))
    {
        <h3>Answer</h3>
        <pre class="answer">@_answer</pre>
    }
    @if (_citations.Count > 0)
    {
        <h3>Citations</h3>
        <ul>
            @foreach (var c in _citations)
            {
                <li>
                    <strong>@c.Title</strong> (score @c.Score.ToString("F3"))
                    <div class="snippet">@c.Snippet</div>
                </li>
            }
        </ul>
    }
</section>

@code {
    private string _ingestText = "";
    private string _question = "";
    private string _answer = "";
    private string _ingestMessage = "";
    private string _statusMessage = "Not probed yet.";
    private string _datasetMessage = "Starting download (skip if already present)…";
    private bool _busy;
    private long _docCount;
    private List<RagCitation> _citations = [];

    protected override async Task OnInitializedAsync()
    {
        RefreshStats();
        _ = TrackDatasetsAsync();
        await RefreshStatusAsync();
    }

    private void RefreshStats() => _docCount = Collection.Stats.DocCount;

    private async Task TrackDatasetsAsync()
    {
        try
        {
            _datasetMessage = "Downloading datasets…";
            await InvokeAsync(StateHasChanged);
            var progress = new Progress<string>(msg =>
            {
                _datasetMessage = msg;
                _ = InvokeAsync(StateHasChanged);
            });
            await SampleDatasetBootstrap.EnsureAllAsync(progress);
            _datasetMessage = "Datasets ready (or skipped if already present).";
        }
        catch (Exception ex)
        {
            _datasetMessage = $"Download issue: {ex.Message}. T0 fixtures still work.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshStatusAsync()
    {
        try
        {
            var status = await StatusProbe.ProbeAsync();
            var embed = status.EmbeddingsOk ? "green" : "red";
            var chat = status.ChatOk ? "green" : "red";
            _statusMessage = $"{status.Message} [embed:{embed} chat:{chat}]";
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task IngestAsync()
    {
        if (string.IsNullOrWhiteSpace(_ingestText))
        {
            _ingestMessage = "Paste some text first.";
            return;
        }

        _busy = true;
        try
        {
            var result = await Ingest.IngestTextAsync("maui-paste", "maui", _ingestText, "maui");
            _ingestMessage = $"Stored {result.ChunkCount} chunk(s).";
            RefreshStats();
        }
        catch (Exception ex)
        {
            _ingestMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task IngestFixturesAsync()
    {
        _busy = true;
        try
        {
            var fixtures = FixtureLoader.LoadRagFixtures();
            var total = 0;
            foreach (var fx in fixtures)
            {
                var result = await Ingest.IngestTextAsync(fx.Title, fx.Source, fx.Body, fx.Tags);
                total += result.ChunkCount;
            }
            _ingestMessage = fixtures.Count == 0
                ? "No fixtures found (check samples/datasets/fixtures/rag)."
                : $"Ingested {total} chunk(s) from {fixtures.Count} fixture file(s).";
            RefreshStats();
        }
        catch (Exception ex)
        {
            _ingestMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AskAsync()
    {
        if (string.IsNullOrWhiteSpace(_question))
            return;

        _busy = true;
        try
        {
            var result = await Ask.AskAsync(_question);
            _answer = result.Answer;
            _citations = result.Citations.ToList();
        }
        catch (Exception ex)
        {
            _answer = ex.Message;
            _citations = [];
        }
        finally
        {
            _busy = false;
        }
    }
}

<style>
    .status { color: #555; margin-bottom: 1rem; }
    .status-bar { padding: .75rem; background: #f4f4f4; margin-bottom: 1rem; border-radius: 4px; }
    section { margin-bottom: 2rem; }
    .actions { margin-top: .5rem; display: flex; gap: .5rem; }
    .answer { white-space: pre-wrap; background: #fafafa; padding: 1rem; }
    .snippet { color: #444; font-size: .9rem; }
    .btn { padding: .4rem .8rem; cursor: pointer; }
    .btn-primary { background: #0b5fff; color: #fff; border: none; }
</style>
