diff --git a/thirdparty/arrow/CMakeLists.txt b/thirdparty/arrow/CMakeLists.txt
index d6d926d..3bb81c3 100644
--- a/thirdparty/arrow/CMakeLists.txt
+++ b/thirdparty/arrow/CMakeLists.txt
@@ -144,12 +144,27 @@ elseif (MSVC)
                 LOG_INSTALL ON
         )
 else ()
+    # Cross-compile (e.g. linux-arm64 on x86_64 host): Arrow's EP must see the
+    # target processor or it enables SSE4.2 and configure fails.
+    # Linux aarch64 only (native or cross). Do not key on CMAKE_CROSSCOMPILING ???
+    # same SYSTEM_NAME as the host leaves it false. Skip Darwin (osx-arm64 uses else()).
+    set(_ARROW_CROSS_ARGS "")
+    if(CMAKE_SYSTEM_NAME STREQUAL "Linux" AND CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64|arm64|ARM64")
+        list(APPEND _ARROW_CROSS_ARGS
+            -DCMAKE_SYSTEM_NAME=${CMAKE_SYSTEM_NAME}
+            -DCMAKE_SYSTEM_PROCESSOR=${CMAKE_SYSTEM_PROCESSOR}
+            -DARROW_SIMD_LEVEL=NEON
+            -DARROW_RUNTIME_SIMD_LEVEL=MAX
+            -DARROW_WITH_OPENSSL=OFF
+        )
+        message(STATUS "Arrow EP cross args: ${_ARROW_CROSS_ARGS}")
+    endif()
     ExternalProject_Add(
             ARROW.BUILD PREFIX arrow
             SOURCE_DIR ${CMAKE_CURRENT_SOURCE_DIR}/apache-arrow-21.0.0
             DOWNLOAD_COMMAND ""
             BUILD_IN_SOURCE false
-            CONFIGURE_COMMAND env ${CONFIGURE_ENV_LIST} "${CMAKE_COMMAND}" ${CMAKE_CACHE_ARGS} ${_ARROW_COMPILER_LAUNCHER_ARGS} ${_ARROW_COMPILER_ARGS} -DCMAKE_BUILD_TYPE=${ARROW_CMAKE_BUILD_TYPE} -DCMAKE_DEBUG_POSTFIX= -DARROW_BUILD_SHARED=OFF -DARROW_ACERO=ON -DARROW_FILESYSTEM=ON -DARROW_DATASET=ON -DARROW_PARQUET=ON -DARROW_COMPUTE=ON -DARROW_WITH_ZLIB=OFF -DARROW_DEPENDENCY_SOURCE=BUNDLED -DARROW_MIMALLOC=OFF -DCMAKE_INSTALL_LIBDIR=lib "<SOURCE_DIR>/cpp"
+            CONFIGURE_COMMAND env ${CONFIGURE_ENV_LIST} "${CMAKE_COMMAND}" ${CMAKE_CACHE_ARGS} ${_ARROW_COMPILER_LAUNCHER_ARGS} ${_ARROW_COMPILER_ARGS} ${_ARROW_CROSS_ARGS} -DCMAKE_BUILD_TYPE=${ARROW_CMAKE_BUILD_TYPE} -DCMAKE_DEBUG_POSTFIX= -DARROW_BUILD_SHARED=OFF -DARROW_ACERO=ON -DARROW_FILESYSTEM=ON -DARROW_DATASET=ON -DARROW_PARQUET=ON -DARROW_COMPUTE=ON -DARROW_WITH_ZLIB=OFF -DARROW_DEPENDENCY_SOURCE=BUNDLED -DARROW_MIMALLOC=OFF -DCMAKE_INSTALL_LIBDIR=lib "<SOURCE_DIR>/cpp"
             BUILD_COMMAND "${CMAKE_COMMAND}" --build . --target all -- -j ${NPROC}
             INSTALL_COMMAND "${CMAKE_COMMAND}" --install "<BINARY_DIR>" --prefix=${EXTERNAL_BINARY_DIR}/usr/local
             BYPRODUCTS ${LIB_PARQUET} ${LIB_ARROW} ${LIB_COMPUTE} ${LIB_ACERO} ${LIB_ARROW_DEPENDS} ${LIB_ARROW_DATASET}
@@ -157,6 +172,7 @@ else ()
             LOG_CONFIGURE ON
             LOG_BUILD ON
             LOG_INSTALL ON
+            LOG_OUTPUT_ON_FAILURE ON
     )
 endif()
 
